# Ollama 接続先（省略時は http://localhost:11434）
# OLLAMA_BASE_URL=http://localhost:11434

# 使用するモデル名（省略時は qwen3:4b）
# OLLAMA_MODEL=qwen3:4b

# メインモデルが視覚対応の場合 true（画像付きメッセージを扱う）。デフォルト true
# OLLAMA_VISION_ENABLED=true

# リクエストタイムアウト（秒）（省略時は 60）
# OLLAMA_TIMEOUT=60

# fetch_page（URL 先のページ取得）
# FETCH_PAGE_TIMEOUT=15
# FETCH_PAGE_MAX_BYTES=1000000
# FETCH_PAGE_MAX_CHARS=8000

# SearXNG 接続先（省略時は http://localhost:8080）
# SEARXNG_URL=http://localhost:8080

# SearXNG 認証
# Bearer トークン:
# SEARXNG_TOKEN=your_token

# Basic 認証:
# SEARXNG_USER=user
# SEARXNG_PASSWORD=password

# ログ
# ANCILLA_LOG_LEVEL=INFO
# ANCILLA_LOG_FILE=data/logs/ancilla.log

# 短期記憶（会話履歴）の最大文字数（ざっくりトークン上限の代わり）
# ANCILLA_MAX_HISTORY_CHARS=4000

# 会話履歴の保存先
# ANCILLA_CONVERSATION_DIR=data/conversation

# 主記憶（システムプロンプト）の Markdown を置くディレクトリ
# ANCILLA_PROMPTS_DIR=data/prompts

# エージェントの作業範囲（読み書き許可はこのディレクトリ以下のみ）
# ANCILLA_WORKSPACE_DIR=workspace

# bash ツール: 許可するコマンド先頭トークン（カンマ区切り）。未設定なら全コマンド許可
# ANCILLA_BASH_ALLOWLIST=ls,cat,python

# bash サンドボックス: none（ホスト直接実行）| docker（コンテナ内実行）
# ANCILLA_SANDBOX=none
# ANCILLA_SANDBOX_IMAGE=ancilla-sandbox

# 能動通知キューの保存先
# ANCILLA_NOTIFICATIONS_DIR=data/notifications

# 構造化ユーザーモデル（YAML）
# ANCILLA_PERSONAL_MODEL_PATH=data/personal_model.yaml

# Proactive Engine（自律介入）
# ANCILLA_PROACTIVE_MAX_PER_HOUR=2
# 0 で完全無効化
# ANCILLA_PROACTIVE_RULES_PATH=data/proactive_rules.yaml

# ドメインプラグイン（カンマ区切り: research,learning,meeting）
# ANCILLA_PLUGINS=research

# 会話履歴圧縮の発火比率（active 上限に対する割合、省略時 0.8）
# ANCILLA_TIER2_TRIGGER_RATIO=0.8

# Slow Heartbeat の実行時刻（HH:MM、省略時 03:00）
# ANCILLA_HEARTBEAT_TIME=03:00

# Ambient Layer: カメラ定期取得間隔（分）。0 で無効
# ANCILLA_CAMERA_INTERVAL=0

# Self-Reflection: 回答を返す前に 1 回だけ LLM で検証する（true/false）。無効にする場合は false
# ANCILLA_VERIFY_ANSWER=true

# 検証を「ツールを 1 回以上呼んだときだけ」行う。常時検証する場合は false
# ANCILLA_VERIFY_ONLY_AFTER_TOOL=true

# ReAct の最大ツール呼び出しターン数（省略時は 15）。複雑なタスクでは増やすと精度が上がる
# ANCILLA_MAX_TOOL_TURNS=15

# ツール呼び出しモード: gbnf（JSON Schema 制約）| native（Ollama tools=）
# native 時は workspace/AGENT.native.md と data/prompts/TOOLS.native.md が使われる（JSON 出力指示なし）
# ANCILLA_TOOL_MODE=gbnf

# Self-Reflection / Personal Model 更新用の軽量モデル（省略時は OLLAMA_MODEL）
# ANCILLA_VERIFY_MODEL=qwen3:4b

# 長期記憶の保存先
# ANCILLA_VECTOR_STORE_DIR=data/vector_store

# 埋め込み用モデル
# OLLAMA_EMBED_MODEL=nomic-embed-text

# Discord Bot（ancilla discord 用）。トークンは Discord 開発者ポータルで発行
# DISCORD_BOT_TOKEN=your_bot_token
# 能動通知の送り先（リマインダー等）。チャンネル ID かユーザー ID のどちらかを設定
# DISCORD_NOTIFY_CHANNEL_ID=123456789012345678
# DISCORD_NOTIFY_USER_ID=123456789012345678

# Slack Bot（ancilla slack 用）。Socket Mode を使用するため公開 URL 不要
# Bot User OAuth Token（xoxb-...）: Slack アプリの OAuth & Permissions で発行
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# App-Level Token（xapp-...）: Settings → Socket Mode → Enable して connections:write スコープで発行
# SLACK_APP_TOKEN=xapp-your-app-token
# 能動通知の送り先チャンネル ID（例: C0123456789）。未設定なら通知はしない
# SLACK_NOTIFY_CHANNEL_ID=C0123456789
# デーモン API のホスト・ポート（ancilla run で起動する API）。クライアント・Discord が接続
# ANCILLA_API_HOST=127.0.0.1
# ANCILLA_API_PORT=8765

# WebSocket サーバーのポート（Unity 等フロントエンド接続用）。省略時は 8766
# ANCILLA_WS_PORT=8766

# 自律観察ループ（エッジデバイス接続中に定期的に画面を観察してコメントする）
# 有効/無効（デフォルト true）
# ANCILLA_OBS_ENABLED=true
# 画像変化チェック間隔（秒）（デフォルト 10）
# ANCILLA_OBS_POLL_SEC=10
# コメント生成の最短間隔（秒）。前回コメントからこの時間以上経過かつ画面変化があればコメント（デフォルト 45）
# ANCILLA_OBS_MIN_INTERVAL_SEC=45
# この時間（秒）以上経過すれば画面変化がなくてもコメントする上限（デフォルト 180）
# ANCILLA_OBS_MAX_INTERVAL_SEC=180

# Idle Reflection: ユーザー入力が途絶えた時に自律的に行動するループ
# 最終入力からこの分数が経過したら reflection を発動（デフォルト 30 分）
# ANCILLA_IDLE_THRESHOLD_MIN=30
# reflection と reflection の間に空ける最小間隔（分）（デフォルト 60 分）
# ANCILLA_IDLE_COOLDOWN_MIN=60
# idle reflection 1 回あたりの最大ツール呼び出しターン数（デフォルト 8）
# ANCILLA_IDLE_MAX_TOOL_TURNS=8

# STT (faster-whisper-server) のベース URL。音声→テキスト（WS 音声入力用）。未設定なら STT は行わない
# STT_BASE_URL=http://localhost:8000

# TTS (Coeiroink) のベース URL。テキスト→音声（WS agent_response 用）。未設定なら音声は返さない
# TTS_BASE_URL=http://localhost:50033
