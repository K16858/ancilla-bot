# Ollama 接続先（省略時は http://localhost:11434）
# OLLAMA_BASE_URL=http://localhost:11434

# 使用するモデル名（省略時は qwen3:4b）
# OLLAMA_MODEL=qwen3:4b

# メインモデルが視覚対応の場合 true（画像付きメッセージを扱う）。デフォルト true
# OLLAMA_VISION_ENABLED=true

# リクエストタイムアウト（秒）（省略時は 60）
# OLLAMA_TIMEOUT=60

# fetch_page（URL 先のページ取得）
# FETCH_PAGE_TIMEOUT=15
# FETCH_PAGE_MAX_BYTES=1000000
# FETCH_PAGE_MAX_CHARS=8000

# SearXNG 接続先（省略時は http://localhost:8080）
# SEARXNG_URL=http://localhost:8080

# SearXNG 認証
# Bearer トークン:
# SEARXNG_TOKEN=your_token

# Basic 認証:
# SEARXNG_USER=user
# SEARXNG_PASSWORD=password

# ログ
# ANCILLA_LOG_LEVEL=INFO
# ANCILLA_LOG_FILE=data/logs/ancilla.log

# 短期記憶（会話履歴）の最大文字数（ざっくりトークン上限の代わり）
# ANCILLA_MAX_HISTORY_CHARS=4000

# 会話履歴の保存先
# ANCILLA_CONVERSATION_DIR=data/conversation

# 主記憶（システムプロンプト）の Markdown を置くディレクトリ
# ANCILLA_PROMPTS_DIR=data/prompts

# エージェントの作業範囲（読み書き許可はこのディレクトリ以下のみ）
# ANCILLA_WORKSPACE_DIR=workspace

# Self-Reflection: 回答を返す前に 1 回だけ LLM で検証する（true/false）。無効にする場合は false
# ANCILLA_VERIFY_ANSWER=true

# 検証を「ツールを 1 回以上呼んだときだけ」行う。常時検証する場合は false
# ANCILLA_VERIFY_ONLY_AFTER_TOOL=true

# 長期記憶の保存先
# ANCILLA_VECTOR_STORE_DIR=data/vector_store

# 埋め込み用モデル
# OLLAMA_EMBED_MODEL=nomic-embed-text

# Discord Bot（ancilla discord 用）。トークンは Discord 開発者ポータルで発行
# DISCORD_BOT_TOKEN=your_bot_token
# 能動通知の送り先（リマインダー等）。チャンネル ID かユーザー ID のどちらかを設定
# DISCORD_NOTIFY_CHANNEL_ID=123456789012345678
# DISCORD_NOTIFY_USER_ID=123456789012345678
# デーモン API のポート（ancilla run で起動する API）。クライアント・Discord が接続
# ANCILLA_API_PORT=8765

# WebSocket サーバーのポート（Unity 等フロントエンド接続用）。省略時は 8766
# ANCILLA_WS_PORT=8766

# STT (faster-whisper-server) のベース URL。音声→テキスト（WS 音声入力用）。未設定なら STT は行わない
# STT_BASE_URL=http://localhost:8000

# TTS (Coeiroink) のベース URL。テキスト→音声（WS agent_response 用）。未設定なら音声は返さない
# TTS_BASE_URL=http://localhost:50033
